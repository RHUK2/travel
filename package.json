{
  "name": "travel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "rm -rf .next && next dev",
    "doctor": "npx -y react-doctor@latest .",
    "type": "tsc --noEmit",
    "lint": "eslint . --max-warnings 10",
    "prebuild": "pnpm run type && pnpm run lint",
    "build": "next build",
    "start": "next start",
    "clean": "rm -rf .next node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "audit": "pnpm audit --audit-level=high",
    "deps:check": "pnpm -r outdated",
    "deps:update": "pnpm -r update && pnpm build",
    "deps:update:major": "pnpm -r up -iL"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "immer": "^11.1.8",
    "lucide-react": "^1.20.0",
    "maplibre-gl": "^5.24.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-easy-crop": "^6.0.2",
    "react-hook-form": "^7.79.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  }
}
